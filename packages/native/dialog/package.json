{
  "name": "@dunky.dev/native-dialog",
  "version": "0.0.0",
  "description": "React Native binding for @dunky.dev/dialog.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dunky-dev/ui.git",
    "directory": "packages/native/dialog"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@dunky.dev/dialog": "workspace:*",
    "@dunky.dev/native-state-machine": "^0.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "^0.86.0",
    "react-native-web": "^0.21.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
