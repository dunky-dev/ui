{
  "name": "@dunky.dev/controllable",
  "version": "0.1.0",
  "description": "Controlled/uncontrolled machinery for state machines: a controllable context slice and gated transitions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dunky-dev/ui.git",
    "directory": "packages/core/utils/controllable"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@dunky.dev/state-machine": "^0.1.0"
  }
}
